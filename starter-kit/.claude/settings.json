{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-dangerous-commands.sh" }]
      }
    ]
  },
  "permissions": {
    "deny": ["Bash(rm -rf /*)", "Bash(rm -rf ~/*)", "Read(**/*.pem)", "Read(~/.ssh/**)"],
    "ask": ["Bash(git push*)", "Read(**/.env*)"],
    "allow": ["Bash", "Read", "Edit", "Write", "Grep", "Glob", "WebFetch", "WebSearch", "TodoRead", "TodoWrite"]
  }
}
